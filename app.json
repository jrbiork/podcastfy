{
  "expo": {
    "name": "Podcastify",
    "slug": "Podcastify",
    "scheme": "podcastify",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-sonera.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "icon": "./assets/ios-icon-sonera.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.rbiork.Podcastify",
      "infoPlist": {
        "CFBundleDisplayName": "Sonera",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A1A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.rbiork.Podcastify",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {},
    "plugins": [
      "expo-av",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.979236713408-1dgu7kko7r3p3jivaq4jsnhfa87mp929"
        }
      ],
      [
        "expo-share-extension",
        {
          "activationRules": [
            {
              "type": "url"
            },
            {
              "type": "file",
              "utis": [
                "com.adobe.pdf"
              ]
            }
          ],
          "backgroundColor": {
            "red": 10,
            "green": 10,
            "blue": 26,
            "alpha": 255
          },
          "height": 200,
          "excludedPackages": [
            "expo-dev-client",
            "expo-splash-screen",
            "expo-updates",
            "expo-font",
            "react-native-purchases"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "PodcastifyShareExtension",
                  "bundleIdentifier": "com.rbiork.Podcastify.ShareExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.rbiork.Podcastify"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "09265e56-fd9c-41cc-a5a2-dfed5eba771e"
      },
      "appleApplicationGroup": "group.com.rbiork.Podcastify"
    },
    "owner": "rbiork"
  }
}

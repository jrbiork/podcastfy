# ── Lambda environment variables ───────────────────────────────────────────
# These are passed as CloudFormation parameters during `sam deploy`.
# Never commit actual values. Copy this file to lambdas/.env for local testing.

# Google OAuth client ID used for JWT verification (mobile client id is fine)
GOOGLE_CLIENT_ID=

# Apple bundle ID (e.g. com.rbiork.Podcastify)
APPLE_CLIENT_ID=com.rbiork.Podcastify

# S3 bucket name — auto-set by SAM in production
S3_BUCKET=podcastify-jobs-<account-id>

# SQS queue URL — auto-set by SAM in production, needed only for dispatcher locally
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account-id>/podcastify-jobs

# OpenAI API key (worker only)
OPENAI_API_KEY=

# ElevenLabs API key (worker only)
ELEVENLABS_API_KEY=

# ── Frontend (Expo) ────────────────────────────────────────────────────────
# All EXPO_PUBLIC_ vars are bundled into the JS — never put secrets here.

# Google OAuth client IDs (create at console.cloud.google.com)
# Podcastify is mobile-first; you can omit a Web client ID if you don't target web.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# API Gateway base URL — copy from "cdk deploy" output: ApiBaseUrl
EXPO_PUBLIC_API_BASE=https://<api-id>.execute-api.us-east-1.amazonaws.com

# ── CDK deploy-time secrets (export these before running cdk deploy) ─────────
# These are NOT bundled into the app — they go into Lambda env vars.
GOOGLE_CLIENT_ID=
# iOS client ID — Lambda accepts tokens issued with this audience (iOS Google Sign-In)
GOOGLE_IOS_CLIENT_ID=
APPLE_CLIENT_ID=com.rbiork.Podcastify
OPENAI_API_KEY=

# ── RevenueCat iOS API key (get from app.revenuecat.com → Project → API Keys)
EXPO_PUBLIC_REVENUECAT_IOS=
# Optional: sandbox key for local dev (__DEV__ only)
EXPO_PUBLIC_REVENUECAT_IOS_TEST=
